    "test:api:html": "newman run api/postman/restful-booker.collection.json -e api/postman/restful-booker.environment.json --reporters cli,htmlextra --reporter-htmlextra-export api/postman/results/newman-report.html",
    "test:api:data": "newman run api/postman/restful-booker.collection.json --folder \"CreateBooking — Data Driven\" -e api/postman/restful-booker.environment.json -d api/postman/data/create-booking-testdata.json --reporters cli,htmlextra --reporter-htmlextra-export api/postman/results/newman-data-driven-report.html",
    "test:api:chained": "newman run api/postman/restful-booker.collection.json --folder \"Chained Flow\" -e api/postman/restful-booker.environment.json --reporters cli,htmlextra --reporter-htmlextra-export api/postman/results/newman-chained-report.html",
    "report:api": "open-cli api/postman/results/newman-report.html",
    "report:api:data": "open-cli api/postman/results/newman-data-driven-report.html",
